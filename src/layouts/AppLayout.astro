---
import BottomNav from '../components/BottomNav.astro';
import 'bootstrap/dist/css/bootstrap.min.css';

interface Props {
  title: string;
  currentPath: string;
}

const { title, currentPath } = Astro.props;
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <meta name="theme-color" content="#f8f9fa" />
  <title>{title}</title>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />
  <script is:inline src="/src/js/main.js"></script>
</head>

<body class="bg-secondary bg-opacity-25 d-flex justify-content-center align-items-center vh-100 m-0">


<div class="app-container bg-light d-flex flex-column shadow-lg position-relative overflow-hidden w-100">

  <header class="navbar navbar-light bg-white border-bottom px-3 flex-shrink-0" style="height: 64px;">
    <span class="navbar-brand mb-0 h5 fw-normal">{title}</span>
    <button class="btn btn-light rounded-circle d-flex justify-content-center align-items-center p-0" style="width: 40px; height: 40px;">
      <span class="material-symbols-rounded text-secondary">more_vert</span>
    </button>
  </header>


  <main class="flex-grow-1 overflow-auto bg-light">
    <slot />
  </main>


  <BottomNav currentPath={currentPath} />

</div>


<script>
  import "bootstrap/dist/js/bootstrap.bundle.min.js";
</script>
</body>
</html>

<style is:global>
  * {
    font-family: 'Roboto', sans-serif;
    -webkit-tap-highlight-color: transparent;
  }

  .material-symbols-rounded {
    font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
  }

  .app-container {
    max-width: 412px;
    height: 100vh;
    max-height: 900px;
  }

  @media (max-width: 412px) {
    .app-container {
      height: 100dvh;
      max-height: 100dvh;
      box-shadow: none !important;
    }
  }
</style>