---
import AppLayout from "../layouts/AppLayout.astro";
// import "bootstrap/dist/css/bootstrap.css";
const GOOGLE_API_KEY = "AIzaSyDhluJzFsg9dPELcj6dP-LqXa6iRHYhtwU";
---

<AppLayout title="Event Map" currentPath="/AstroQuest/map">
  <div class="map-wrapper">
    <script
      is:inline
      async
      src={`https://maps.googleapis.com/maps/api/js?key=${GOOGLE_API_KEY}&loading=async&libraries=maps,marker&v=beta`}
    ></script>

    <gmp-map
      center="43.6451,-79.3847"
      zoom="15"
      map-id="map"
      class="gmp-element"
    >
      <gmp-advanced-marker
        position="43.6451,-79.3847"
        title="Metro Toronto Convention Centre"
      >
      </gmp-advanced-marker>
    </gmp-map>

    <div class="map-overlay-card row align-items-start">
      <div class="col">
        <h3>Metro Toronto Convention Centre</h3>
        <p>255 Front St W, Toronto, ON</p>
      </div>
      <div class="col">
        <a type="button" class="btn btn-primary" href="/AstroQuest/mapsettings">
          <span>Map Settings</span>
        </a>
        <input type="checkbox" id="toggle-overlay"></input>
        <label>Overlay</label>
      </div>
    </div>
  </div>
  <script type="module">
    import { createLightPollutionOverlay } from "../lib/LightPollutionOverlay.ts";

    // Wait for the <gmp-map> custom element to be fully upgraded
    await customElements.whenDefined("gmp-map");

    const mapEl = document.querySelector("gmp-map");

    // Method A: grab innerMap directly
    const map = mapEl.innerMap;

    const overlay = createLightPollutionOverlay(0.6);
    overlay.setMap(map);

    // Expose globally so other scripts/islands can control it
    window.lightPollutionOverlay = overlay;

    // Controls
    document
      .getElementById("toggle-overlay")
      .addEventListener("change", (e) => {
        e.target.checked ? overlay.show() : overlay.hide();
      });
  </script>
</AppLayout>

<style>
  /* ai styles */
  .map-wrapper {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  /* Style the <gmp-map> to fill the container */
  .gmp-element {
    width: 100%;
    height: 100%;
    border: none;
  }

  .map-overlay-card {
    position: absolute;
    bottom: 24px;
    left: 16px;
    right: 16px;
    background-color: var(--md-sys-color-surface-container-high);
    border-radius: 16px;
    padding: 16px;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
    /* Ensure the card floats above the Google Map controls */
    z-index: 1;
  }

  .map-overlay-card h3 {
    font-size: 16px;
    font-weight: 500;
    color: var(--md-sys-color-on-surface);
    margin-bottom: 4px;
  }

  .map-overlay-card p {
    font-size: 14px;
    color: var(--md-sys-color-on-surface-variant);
  }
</style>
