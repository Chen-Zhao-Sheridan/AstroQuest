---
import AppLayout from "../layouts/AppLayout.astro";
// import "bootstrap/dist/css/bootstrap.css";
const GOOGLE_API_KEY = "AIzaSyDhluJzFsg9dPELcj6dP-LqXa6iRHYhtwU";
---

<AppLayout title="Event Map" currentPath="/AstroQuest/map">
  <div class="map-wrapper">
    <script
      is:inline
      async
      src={`https://maps.googleapis.com/maps/api/js?key=${GOOGLE_API_KEY}&loading=async&libraries=maps,marker&v=beta`}
    ></script>

    <gmp-map
      center="43.6451,-79.3847"
      zoom="15"
      map-id="map"
      class="gmp-element"
    >
      <gmp-advanced-marker
        position="43.6451,-79.3847"
        title="Metro Toronto Convention Centre"
      >
      </gmp-advanced-marker>
    </gmp-map>

    <div class="map-overlay-card row align-items-start">
      <div class="col">
        <h3>Metro Toronto Convention Centre</h3>
        <p>255 Front St W, Toronto, ON</p>
      </div>
      <div class="col">
        <span>
          <button class="btn btn-primary" id="map-settings-reveal">Map Settings</button>
        </span>
        <div>
          <input type="checkbox" id="toggle-overlay" />
          <label>Overlay</label>
        </div>
      </div>
    </div>
  </div>
  <div hidden="true" id="map-settings">
    <div class="text-center card card-title">
      <h3>Map Settings</h3>
    </div>
    <div class="card card-body">
      <p>Current Latitude: 43.468116</p>
    </div>
    <div class="card card-body">
      <p>Current Longitude: -79.699455</p>
    </div>
    <div class="card card-body">
      <div class="dropdown">
        Map Overlay:
        <button
          class="btn btn-secondary dropdown-toggle"
          type="button"
          data-bs-toggle="dropdown"
          aria-expanded="false"
          id="overlay-select"
        >
          &lt;select overlay&gt;
        </button>
        <ul class="dropdown-menu">
          <li value="light-pollution-overlay">Light Pollution</li>
          <li value="darkness-overlay">Darkness</li>
        </ul>
      </div>
    </div>
    <div class="card card-body">
      <div class="dropdown">
        Time Select:
        <button
          class="btn btn-secondary dropdown-toggle"
          type="button"
          data-bs-toggle="dropdown"
          aria-expanded="false"
        >
          &lt;select time&gt;
        </button>
        <ul class="dropdown-menu">
          <li>
            00:00
          </li>
          <li>
            00:30
          </li>
          <li>
            01:00
          </li>
          <li>
            ...
          </li>
          <li>
            23:00
          </li>
          <li>
            23:30
          </li>
        </ul>
      </div>
    </div>
    <div class="card card-body">
      <p>Supposed to be a calendar here. Needs implementation.</p>
    </div>
    <div></div>
    <!-- spacer -->
    <div class="card card-body">
      <p>Selected Latitude: n/a</p>
    </div>
    <div class="card card-body">
      <p>Selected Longitude: n/a</p>
    </div>
    <div class="card card-body">
        <button class="btn btn-primary" id="map-settings-hide">Back to Map</button>
    </div>
  </div>
  <script src="../js/map.js"></script>
</AppLayout>

<style>
  /* ai styles */
  .map-wrapper {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  /* Style the <gmp-map> to fill the container */
  .gmp-element {
    width: 100%;
    height: 100%;
    border: none;
  }

  .map-overlay-card {
    position: absolute;
    bottom: 24px;
    left: 16px;
    right: 16px;
    background-color: var(--md-sys-color-surface-container-high);
    border-radius: 16px;
    padding: 16px;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
    /* Ensure the card floats above the Google Map controls */
    z-index: 1;
  }

  .map-overlay-card h3 {
    font-size: 16px;
    font-weight: 500;
    color: var(--md-sys-color-on-surface);
    margin-bottom: 4px;
  }

  .map-overlay-card p {
    font-size: 14px;
    color: var(--md-sys-color-on-surface-variant);
  }
</style>
