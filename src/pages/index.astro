---
import AppLayout from '../layouts/AppLayout.astro';
import TimelineItem from '../components/TimelineItem.astro';

// get next weeks events
const today = new Date();
const nextWeek = new Date();
nextWeek.setDate(today.getDate() + 7);

const formatDate = (date) => date.toISOString().split('T')[0];
const startDate = formatDate(today);
const endDate = formatDate(nextWeek);

const apiUrl = `https://ryu4zpidc7s3d3rbiy7dmpykhm0taduu.lambda-url.us-east-1.on.aws/?start_date=${startDate}&end_date=${endDate}`;

let events = [];

try {
    const response = await fetch(apiUrl);
    const rawData = await response.json();

    // sort events by date
    events = rawData
        .sort((a, b) => {
            const dateTimeA = new Date(`${a.date}T${a.time}`);
            const dateTimeB = new Date(`${b.date}T${b.time}`);
            return dateTimeA.getTime() - dateTimeB.getTime();
        })
        .map(event => ({
            time: `${event.date} | ${event.time} UTC`,
            title: event.event_type,
            description: event.description
        }));
} catch (error) {
    console.error("Error fetching celestial events:", error);
}
---

<AppLayout title="Celestial Timeline" currentPath="/AstroQuest">

    <div class="py-3 ps-2 pe-1">
        <div class="accordion" id="timelineAccordion">
            {events.map((event, index) => (
                <TimelineItem
                    time={event.time}
                    title={event.title}
                    description={event.description}
                />
            ))}
        </div>
    </div>

</AppLayout>