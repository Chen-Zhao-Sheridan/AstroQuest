---
interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
---

<nav class="d-flex justify-content-evenly align-items-center bg-white border-top flex-shrink-0 pb-safe" style="height: 80px;">

  <a href="/AstroQuest" class={`text-decoration-none d-flex flex-column align-items-center ${currentPath === '/AstroQuest' || currentPath === '/' ? 'text-primary' : 'text-secondary'}`}>
    <div class={`d-flex justify-content-center align-items-center rounded-pill mb-1 ${currentPath === '/AstroQuest' || currentPath === '/' ? 'bg-primary bg-opacity-10' : ''}`} style="width: 64px; height: 32px;">
      <span class="material-symbols-rounded" style={currentPath === '/AstroQuest' || currentPath === '/' ? "font-variation-settings: 'FILL' 1;" : ""}>view_timeline</span>
    </div>
    <span style="font-size: 12px; font-weight: 500;">Timeline</span>
  </a>

  <a href="/AstroQuest/map" class={`text-decoration-none d-flex flex-column align-items-center ${currentPath === '/AstroQuest/map' ? 'text-primary' : 'text-secondary'}`}>
    <div class={`d-flex justify-content-center align-items-center rounded-pill mb-1 ${currentPath === '/AstroQuest/map' ? 'bg-primary bg-opacity-10' : ''}`} style="width: 64px; height: 32px;">
      <span class="material-symbols-rounded" style={currentPath === '/AstroQuest/map' ? "font-variation-settings: 'FILL' 1;" : ""}>map</span>
    </div>
    <span style="font-size: 12px; font-weight: 500;">Map</span>
  </a>

</nav>

<style>
  .pb-safe {
    padding-bottom: env(safe-area-inset-bottom);
  }
</style>